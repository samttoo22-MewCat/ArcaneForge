# FalkorDB (property graph database)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=

# Redis (ephemeral state: nonces, sessions, combat, SSE routing)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=change_this_to_a_random_256_bit_hex_string

# Game settings
GAME_GRAPH_NAME=arcaneforge
BATCH_WRITE_INTERVAL_SECONDS=2.0
DM_MODIFIER_CAP=5.0
DM_COMBAT_MODIFIER_CAP=3.0
GRAB_CONTEST_WINDOW_SECONDS=10
NONCE_TTL_SECONDS=300

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
LOG_LEVEL=info
